generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model expenses {
  id       Int      @id @default(autoincrement())
  user_id  Int?
  name     String?
  amount   Decimal? @db.Decimal
  category String?
  users    users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_expenses_users")
}

model users {
  id       Int        @id @default(autoincrement())
  username String?    @unique
  budget   Decimal?   @db.Decimal
  expenses expenses[]
}
